# Azure Web PubSub
AZURE_WEBPUBSUB_CONNECTION_STRING=
AZURE_WEBPUBSUB_HUB_NAME=agentshub
AZURE_WEBPUBSUB_GROUP=realtime-agent-room

# Microsoft Agent Framework (required)
# Required in all cases:
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=

# Auth mode A (recommended for Docker): API key from Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Auth mode B (service principal / managed identity without CLI)
AZURE_AI_PROJECT_ENDPOINT=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# App settings
APP_HOST=0.0.0.0
APP_PORT=8010
APP_LOG_LEVEL=INFO
APP_ENV=development

# SQLAgentX - Azure SQL (plug & play)
AZURE_SQL_CONNECTION_STRING=
SQL_QUERY_TIMEOUT_SECONDS=20
SQL_ROW_LIMIT=200
SQL_REQUIRE_SCHEMA_CATALOG=false
SQL_MAX_RETRY_CORRECTIONS=2
