# Required - Azure Web PubSub service credentials
AZURE_WEBPUBSUB_CONNECTION_STRING=Endpoint=https://<your-service>.webpubsub.azure.com;AccessKey=<key>;Version=1.0;
AZURE_WEBPUBSUB_HUB_NAME=agentshub
AZURE_WEBPUBSUB_GROUP=realtime-agent-room

# Required - Redis persistence (chat memory, sessions, recovery)
REDIS_URL=redis://redis:6379
REDIS_CHAT_TTL_SECONDS=604800
REDIS_CHAT_MAX_MESSAGES=500

# Optional runtime defaults (used mainly in Docker/Container environments)
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1
